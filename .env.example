# Copy this file to .env.local and fill in your Supabase project values.
# Get these from: Supabase Dashboard → Project Settings → API

# Public values — safe to expose to the browser (shipped in the client bundle).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Server-only secret — never expose this to the browser, never commit it.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
